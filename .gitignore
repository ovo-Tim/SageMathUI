.env
.env.local

# Python
__pycache__/
*.pyc
*.pyo
.ruff_cache/

# Android signing (keystore secrets)
src-tauri/gen/android/keystore.properties

# SageMath Android cross-compilation (large binaries)
sagemath-android/

# SageMath desktop bundle (downloaded Python + SymPy runtime)
sagemath-desktop-build/
src-tauri/resources/sagemath-bundle.tar.gz

# Android build assets (bundled Python runtime, generated)
src-tauri/gen/android/app/src/main/assets/
src-tauri/gen/android/app/src/main/jniLibs/

# Agent context / session notes (not source code)
agent-context/
NEXT_STEPS.txt
PHASE4_SUMMARY.txt

# Logs
*.log
